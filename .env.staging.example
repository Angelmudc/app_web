# Staging safe baseline (no production secrets, no real outbound)
APP_ENV=staging

# Bot/WhatsApp safety gates (staging sandbox controlado, no produccion)
WHATSAPP_ENABLED=false
BOT_DRY_RUN=true
BOT_STAGING_MODE=true
BOT_SANDBOX_MODE=true
BOT_AUTOREPLY_ENABLED=false
BOT_AI_ENABLED=false
BOT_PROTOCOL_AUTO_ADVANCE_ENABLED=false
BOT_ALLOW_REAL_CANDIDATE_CREATION_LOCAL=false
BOT_PRACTICE_DEMO_MODE=true

# Conservative AI limits (kept low even with AI off)
BOT_AI_DAILY_REQUEST_LIMIT=5
BOT_AI_SESSION_REQUEST_LIMIT=5
BOT_AI_EVAL_MAX_CASES=5

# Placeholders only (no real secrets)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db_name>
SECRET_KEY=<replace-me>
WHATSAPP_VERIFY_TOKEN=<replace-me>
WHATSAPP_ACCESS_TOKEN=replace_me
WHATSAPP_PHONE_NUMBER_ID=replace_me
OPENAI_API_KEY=<replace-me>
# Real WhatsApp sandbox (owner-only, gated)
BOT_REAL_WHATSAPP_SANDBOX_ENABLED=true
BOT_REAL_WHATSAPP_ALLOWED_NUMBERS=18094233968,+18094233968
BOT_REAL_WHATSAPP_PROVIDER=meta_sandbox
BOT_REAL_WHATSAPP_MANUAL_REVIEW_REQUIRED=true
BOT_REAL_WHATSAPP_OWNER_ONLY=true
BOT_REAL_WHATSAPP_MAX_PER_MIN=6
