APP_ENV=local

# Produccion (solo en servidor seguro)
DATABASE_URL=postgresql://user:pass@host/prod_db

# Entorno local en Mac
DATABASE_URL_LOCAL=postgresql://user:pass@localhost:5432/domestica_cibao_local?sslmode=disable

# Entorno de pruebas automatizadas
DATABASE_URL_TEST=postgresql://user:pass@localhost/domestica_cibao_test

# Requerido en produccion para sesiones Flask
FLASK_SECRET_KEY=replace-me
