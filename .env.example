APP_ENV=local

# Produccion (solo en servidor seguro)
DATABASE_URL=postgresql://user:pass@host/prod_db

# Entorno local en Mac
DATABASE_URL_LOCAL=postgresql://user:pass@localhost:5432/domestica_cibao_local?sslmode=disable

# Entorno de pruebas automatizadas
DATABASE_URL_TEST=postgresql://user:pass@localhost/domestica_cibao_test

# Requerido en produccion para sesiones Flask
FLASK_SECRET_KEY=replace-me

# Bot WhatsApp + IA (Fase 4) - defaults seguros
BOT_AI_ENABLED=false
BOT_AUTOREPLY_ENABLED=false
BOT_AI_PROVIDER=openai
BOT_AI_MODEL=gpt-4.1-mini
BOT_AI_API_KEY=
BOT_AI_TIMEOUT_SECONDS=8
BOT_AI_MAX_TOKENS=220
BOT_AI_TEMPERATURE=0
BOT_PRACTICE_DEMO_MODE=true
# Real WhatsApp sandbox (owner-only, gated)
BOT_REAL_WHATSAPP_SANDBOX_ENABLED=false
BOT_REAL_WHATSAPP_ALLOWED_NUMBERS=
BOT_REAL_WHATSAPP_PROVIDER=fake
BOT_REAL_WHATSAPP_MANUAL_REVIEW_REQUIRED=true
BOT_REAL_WHATSAPP_OWNER_ONLY=true
BOT_REAL_WHATSAPP_MAX_PER_MIN=6
